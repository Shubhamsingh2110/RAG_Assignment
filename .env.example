# OpenAI
OPENAI_API_KEY=

# PostgreSQL (pgvector)
DATABASE_URL=postgresql://user:password@127.0.0.1:5434/berkshire_pgvector

# Optional
NODE_ENV=development

# Mastra / Playground
# Port where Mastra playground runs (when using create-mastra)
MASTRA_PLAYGROUND_PORT=4111
# Mastra LLM provider and model
MASTRA_PROVIDER=openai
MASTRA_MODEL=gpt-4o
